<Window x:Class="HeroArena.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1e1e1e">
        <StackPanel Margin="20">

            <TextBlock Text="⚙️ Configuration DB"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Connection String :"
                       Foreground="#aaaaaa"
                       FontSize="12"
                       Margin="0,0,0,5"/>

            <TextBox Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                     Height="35"
                     Background="#2d2d2d"
                     Foreground="White"
                     BorderBrush="#555555"
                     Padding="5"
                     Margin="0,0,0,15"/>

            <Button Content="💾 Sauvegarder"
                    Height="35"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Command="{Binding SaveCommand}"
                    Margin="0,0,0,10"/>

            <Button Content="🌱 Initialiser la base de données"
                    Height="35"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Command="{Binding SeedCommand}"/>

        </StackPanel>
    </Grid>
</Window>