<Window x:Class="HeroArena.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hero Arena" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1e1e1e">
        
        <StackPanel Margin="20">

            <!-- TITRE -->
            <TextBlock Text="🔥 Hero Arena"
                       FontSize="26"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- LISTE DES HEROS -->
            <ListBox ItemsSource="{Binding Heroes}"
                     SelectedItem="{Binding SelectedHero}"
                     Height="200"
                     Background="#2d2d2d"
                     BorderThickness="0"
                     Padding="10">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#3a3a3a"
                                CornerRadius="10"
                                Margin="5"
                                Padding="10">

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           Width="200"/>

                                <TextBlock Text="HP: "
                                           Foreground="Gray"/>

                                <TextBlock Text="{Binding Health}"
                                           Foreground="LightGreen"/>
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

            <!-- BOUTONS -->
            <StackPanel Orientation="Horizontal" Margin="0,10">

                <Button Content="Choisir ce héros"
                        Width="180"
                        Height="40"
                        Margin="5"
                        Background="#4CAF50"
                        Foreground="White"
                        Command="{Binding SelectHeroCommand}"/>

                <Button Content="Voir les spells"
                        Width="150"
                        Height="40"
                        Margin="5"
                        Background="#2196F3"
                        Foreground="White"
                        Click="OpenSpells"/>

                <Button Content="Lancer combat"
                        Width="150"
                        Height="40"
                        Margin="5"
                        Background="#f44336"
                        Foreground="White"
                        Click="OpenCombat"/>

            </StackPanel>

            <!-- DETAILS HERO -->
            <StackPanel Margin="0,20,0,0">

                <TextBlock Text="📋 Détails du héros"
                           FontSize="18"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{Binding HeroName}"
                           Foreground="White"
                           FontSize="16"/>

                <TextBlock Text="{Binding HeroHP, StringFormat=HP: {0}}"
                           Foreground="LightGreen"
                           Margin="0,5,0,10"/>

                <TextBlock Text="Sorts :"
                           Foreground="White"
                           Margin="0,10,0,5"/>

                <ListBox ItemsSource="{Binding HeroSpells}"
                         Background="#2d2d2d"
                         BorderThickness="0">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"/>

                                <TextBlock Text="{Binding Description}"
                                           Foreground="Gray"
                                           FontSize="12"/>

                                <TextBlock Text="{Binding Damage, StringFormat=Dégâts: {0}}"
                                           Foreground="Orange"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>